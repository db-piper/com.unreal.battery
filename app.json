{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.unreal.battery",
  "version": "1.0.1",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "brandColor": "#6b93f2",
  "runtime": "nodejs",
  "platforms": [
    "local"
  ],
  "name": {
    "en": "Unreal Battery"
  },
  "description": {
    "en": "Emulates a Home Battery device for the Homey Energy Tab"
  },
  "category": [
    "energy"
  ],
  "permissions": [],
  "images": {
    "small": "/assets/images/app_small.png",
    "large": "/assets/images/app_large.png",
    "xlarge": "/assets/images/app_xlarge.png"
  },
  "author": {
    "name": "David Piper",
    "email": "david.piper@normandygite.org.uk"
  },
  "flow": {
    "actions": [
      {
        "id": "compute_unreal_battery_update",
        "title": {
          "en": "Compute updated battery values from power and time"
        },
        "titleFormatted": {
          "en": "Update unreal battery with [[soh]], [[soc]], [[temp]], [[power]] every [[time_base]] seconds"
        },
        "hint": {
          "en": "Update battery capabilities by computed energy from power and time"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=unreal-battery"
          },
          {
            "type": "number",
            "name": "soh",
            "placeholder": {
              "en": "Battery Health %"
            },
            "min": 0,
            "max": 100,
            "step": 1
          },
          {
            "type": "number",
            "name": "soc",
            "placeholder": {
              "en": "Charge Level %"
            },
            "min": 0,
            "max": 100,
            "step": 1
          },
          {
            "type": "number",
            "name": "temp",
            "placeholder": {
              "en": "Temperature in Celsius"
            }
          },
          {
            "type": "number",
            "name": "power",
            "placeholder": {
              "en": "Power (positive charging/negative discharging)"
            }
          },
          {
            "type": "number",
            "name": "time_base",
            "placeholder": {
              "en": "Time base in seconds"
            }
          }
        ]
      }
    ]
  },
  "drivers": [
    {
      "name": {
        "en": "Unreal Battery"
      },
      "class": "battery",
      "capabilities": [
        "measure_power",
        "measure_temperature",
        "meter_power.charged",
        "meter_power.discharged",
        "meter_power.charged_today",
        "meter_power.discharged_today",
        "measure_percent.health",
        "measure_percent.soc",
        "measure_percent.round_trip_efficiency",
        "measure_battery"
      ],
      "pair": [
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "capabilitiesOptions": {
        "measure_power": {
          "title": {
            "en": "Power"
          },
          "units": {
            "en": "W"
          },
          "decimals": 0,
          "getable": true
        },
        "measure_temperature": {
          "title": {
            "en": "Temperature"
          },
          "units": {
            "en": "°C"
          },
          "decimals": 0,
          "getable": true
        },
        "meter_power.charged": {
          "title": {
            "en": "Charged Energy"
          },
          "units": {
            "en": "kWh"
          },
          "decimals": 3,
          "getable": true
        },
        "meter_power.discharged": {
          "title": {
            "en": "Discharged Energy"
          },
          "units": {
            "en": "kWh"
          },
          "decimals": 3,
          "getable": true
        },
        "meter_power.charged_today": {
          "title": {
            "en": "Charged Today"
          },
          "units": {
            "en": "kWh"
          },
          "decimals": 3,
          "getable": true
        },
        "meter_power.discharged_today": {
          "title": {
            "en": "Discharged Today"
          },
          "units": {
            "en": "kWh"
          },
          "decimals": 3,
          "getable": true
        },
        "measure_percent.health": {
          "title": {
            "en": "Battery Health"
          },
          "getable": true
        },
        "measure_percent.soc": {
          "title": {
            "en": "Battery SOC"
          },
          "preventInsights": true,
          "getable": true
        },
        "measure_percent.round_trip_efficiency": {
          "title": {
            "en": "Round Trip Efficiency"
          },
          "getable": true
        },
        "measure_battery": {
          "title": {
            "en": "Battery SOC"
          },
          "units": {
            "en": "%"
          },
          "getable": true
        }
      },
      "energy": {
        "homeBattery": true,
        "meterPowerImportedCapability": "meter_power.charged",
        "meterPowerExportedCapability": "meter_power.discharged"
      },
      "platforms": [
        "local"
      ],
      "connectivity": [],
      "images": {
        "small": "/drivers/unreal-battery/assets/images/driver_small.png",
        "large": "/drivers/unreal-battery/assets/images/driver_large.png",
        "xlarge": "/drivers/unreal-battery/assets/images/driver_xlarge.png"
      },
      "id": "unreal-battery"
    }
  ],
  "capabilities": {
    "measure_percent": {
      "type": "number",
      "getable": true,
      "setable": false,
      "icon": "/assets/tax.svg",
      "insights": true,
      "uiComponent": "sensor",
      "decimals": 0,
      "title": {
        "en": "%"
      },
      "units": {
        "en": "%"
      }
    }
  }
}